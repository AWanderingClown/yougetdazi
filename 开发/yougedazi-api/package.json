{
  "name": "pp-mate-api",
  "version": "1.0.0",
  "description": "PP-Mate 陪玩平台后端 API",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/app.ts",
    "build": "tsup src/app.ts --format esm --dts",
    "start": "node dist/app.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:stress": "vitest run __tests__/stress",
    "test:performance": "vitest run __tests__/performance --testTimeout=60000",
    "test:security": "vitest run __tests__/security/auth-security.test.ts --testTimeout=30000",
    "test:perf-sec": "bash scripts/run-performance-security-tests.sh",
    "test:report": "vitest run --reporter=verbose --reporter=json --outputFile=./test-results.json"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.13.2",
    "dayjs": "^1.11.13",
    "fastify": "^5.8.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "wechatpay-node-v3": "^2.2.1",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autocannon": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
