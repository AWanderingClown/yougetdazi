# ============================================
# PP-Mate API 环境配置模板
# 复制此文件为 .env 并根据环境修改
# ============================================

# --------------------------------------------
# 基础配置
# --------------------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/ppmate_db"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your-jwt-secret-key-minimum-32-characters-long"
# Admin 独立 JWT secret，必须与 JWT_SECRET 不同（物理隔离防止 token 跨端使用）
ADMIN_JWT_SECRET="your-admin-jwt-secret-key-different-from-jwt-secret-minimum-32-characters"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development

# --------------------------------------------
# 微信小程序配置
# --------------------------------------------

# 开发测试模式开关
# true:  使用模拟微信登录（无需真实小程序账号，适合开发测试）
# false: 使用真实微信登录（需要配置下方真实AppID和Secret）
WX_MOCK_LOGIN=true

# 微信小程序（C端用户）
# 开发测试时可使用 TODO_ 前缀，生产环境必须使用真实值
WX_C_APP_ID="TODO_wx_c_app_id"
WX_C_APP_SECRET="TODO_wx_c_app_secret"

# 微信小程序（B端陪玩师）
# 开发测试时可使用 TODO_ 前缀，生产环境必须使用真实值
WX_B_APP_ID="TODO_wx_b_app_id"
WX_B_APP_SECRET="TODO_wx_b_app_secret"

# --------------------------------------------
# 微信支付配置（可选，用于支付功能）
# --------------------------------------------
WX_PAY_MCH_ID="your_mch_id"
WX_PAY_PRIVATE_KEY="your_private_key"
WX_PAY_SERIAL_NO="your_serial_no"
WX_PAY_API_V3_KEY="your_api_v3_key"
WX_PAY_NOTIFY_URL="https://your-domain.com/webhook/wx-pay"

# --------------------------------------------
# 腾讯云 COS 配置（可选，用于文件上传）
# --------------------------------------------
COS_SECRET_ID="your_secret_id"
COS_SECRET_KEY="your_secret_key"
COS_BUCKET="your_bucket_name"
COS_REGION="ap-guangzhou"

# --------------------------------------------
# 安全相关配置
# --------------------------------------------
# 敏感字段加密密钥（32字节 hex = 64字符）
FIELD_ENCRYPT_KEY="a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"

# CORS 生产域名（逗号分隔，开发环境忽略）
CORS_ORIGINS="https://your-domain.com,https://admin.your-domain.com"
