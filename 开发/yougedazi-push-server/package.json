{
  "name": "yougedazi-push-server",
  "version": "1.0.0",
  "description": "有个搭子 推送中继服务 —— 接收主后端推送事件，转发给 C端/B端 Socket.IO 客户端",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsup src/app.ts --format esm --out-dir dist",
    "start": "node dist/app.js",
    "test": "vitest"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "dotenv": "^17.3.1",
    "fast-jwt": "^6.1.0",
    "fastify": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.3",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
