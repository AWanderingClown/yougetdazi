# ============================================
# 推送服务器环境配置模板
# 复制此文件为 .env 并填入真实值后启动服务：
#   cp .env.example .env
# ============================================

# 推送服务器端口
PORT=3002

# C/B端 Socket.IO JWT 密钥（必须与主后端 JWT_SECRET 一致）
JWT_SECRET="your-jwt-secret-key-minimum-32-characters-long"

# Admin 管理后台 JWT 密钥（必须与主后端 ADMIN_JWT_SECRET 一致）
ADMIN_JWT_SECRET="your-admin-jwt-secret-key-minimum-32-characters-long"

# 推送 API Key（主后端通过 X-Push-Api-Key 请求头传入，必须与主后端 PUSH_API_KEY 一致）
PUSH_API_KEY="your-push-api-key"

# CORS 生产域名（逗号分隔，开发环境自动放行 *）
CORS_ORIGINS="https://admin.yougedazi.icu,https://yougedazi.icu"

# 生产部署时必须显式设置为 production
NODE_ENV=development
