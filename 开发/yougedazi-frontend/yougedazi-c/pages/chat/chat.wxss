/* pages/chat/chat.wxss - 紫色主题聊天页 */

page {
  --primary-color: #7B68EE;
  --primary-dark: #5A4ACF;
  --bg-color: #f8f9fa;
  --bubble-left: #ffffff;
  
  background-color: var(--bg-color);
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部导航 - 紫色渐变 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.back-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 64rpx;
  color: #fff;
  font-weight: 300;
}

.nav-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding-top: 8rpx;
  height: 100%;
  box-sizing: border-box;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.3;
}

.online-status {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 2rpx;
  display: flex;
  align-items: center;
  line-height: 1.3;
}

.online-status::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  background: #52C41A;
  border-radius: 50%;
  margin-right: 6rpx;
}

.more-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-icon {
  font-size: 40rpx;
  color: #fff;
}

/* 聊天内容区域 */
.chat-content {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

/* 时间提示 */
.time-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin: 24rpx 0;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 20rpx;
  display: inline-block;
  left: 50%;
  transform: translateX(-50%);
  position: relative;
}

/* 消息行 */
.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.message-row.left {
  justify-content: flex-start;
}

.message-row.right {
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.message-row.left .avatar {
  margin-right: 20rpx;
}

.message-row.right .avatar {
  margin-left: 20rpx;
}

/* 消息气泡 */
.message-bubble {
  max-width: 65%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  word-wrap: break-word;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 对方消息 - 白色 */
.message-bubble.left {
  background: var(--bubble-left);
  border-top-left-radius: 4rpx;
}

/* 自己消息 - 紫色渐变 */
.message-bubble.right {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-top-right-radius: 4rpx;
}

.message-text {
  font-size: 30rpx;
  line-height: 1.5;
}

.message-bubble.left .message-text {
  color: #333;
}

.message-bubble.right .message-text {
  color: #fff;
}

/* 底部输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}

.input-wrapper {
  flex: 1;
  margin-right: 20rpx;
}

/* 图片按钮 */
.image-btn {
  width: 40rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  margin-left: 8rpx;
  background: #f0f0f0;
  color: #555;
  font-size: 28rpx;
}

.message-input {
  height: 76rpx;
  padding: 0 28rpx;
  background: #f5f6fa;
  border-radius: 38rpx;
  font-size: 28rpx;
  color: #333;
}

/* 发送按钮 - 渐变 */
.send-btn {
  width: 120rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ddd;
  border-radius: 38rpx;
  transition: all 0.3s;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.send-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  background: #ffffff;
}
