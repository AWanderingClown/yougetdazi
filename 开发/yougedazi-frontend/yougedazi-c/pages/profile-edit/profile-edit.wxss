/* pages/profile-edit/profile-edit.wxss */

.container {
  min-height: 100vh;
  background: #f8f8f8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 头像编辑区域 */
.avatar-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 0;
  display: flex;
  justify-content: center;
  position: relative;
}

.avatar-section::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #f8f8f8;
  border-radius: 40rpx 40rpx 0 0;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  z-index: 1;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.avatar-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s;
}

.avatar-wrapper:active .avatar-mask {
  opacity: 1;
}

.camera-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.avatar-tip {
  font-size: 24rpx;
  color: #fff;
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item.disabled {
  background: #fafafa;
}

.form-label {
  width: 140rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  text-align: right;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.value-text {
  font-size: 30rpx;
  color: #333;
}

.arrow-icon {
  font-size: 32rpx;
  color: #999;
  margin-left: 12rpx;
}

.bind-tip {
  font-size: 24rpx;
  color: #667eea;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
}

/* 性别选择 */
.gender-options {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
}

.gender-option {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: #f5f6fa;
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.gender-option.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.gender-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  color: #999;
}

.gender-option.active .gender-icon {
  color: #fff;
}

.gender-text {
  font-size: 28rpx;
  color: #666;
}

.gender-option.active .gender-text {
  color: #fff;
}

/* 保存按钮 */
.save-section {
  padding: 40rpx 20rpx 0;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  padding: 40rpx 0;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

/* 年龄选择弹窗 */
.age-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.age-list {
  max-height: 60vh;
  overflow-y: auto;
  padding: 20rpx 0;
}

.age-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.age-item.active {
  background: rgba(102, 126, 234, 0.05);
}

.age-text {
  font-size: 30rpx;
  color: #333;
}

.age-item.active .age-text {
  color: #667eea;
  font-weight: 500;
}

.check-icon {
  font-size: 32rpx;
  color: #667eea;
}
