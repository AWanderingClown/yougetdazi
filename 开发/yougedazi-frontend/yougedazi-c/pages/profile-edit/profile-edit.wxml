<!-- pages/profile-edit/profile-edit.wxml -->
<view class="container">
  <!-- 头像编辑区域 -->
  <view class="avatar-section">
    <view class="avatar-wrapper" bindtap="onChangeAvatar">
      <image class="user-avatar" src="{{userInfo.avatar}}" mode="aspectFill"/>
      <view class="avatar-mask">
        <text class="camera-icon">📷</text>
        <text class="avatar-tip">更换头像</text>
      </view>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section">
    <!-- 昵称 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input 
        class="form-input" 
        value="{{userInfo.nickname}}" 
        placeholder="请输入昵称"
        maxlength="20"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="gender-options">
        <view 
          class="gender-option {{userInfo.gender === '男' ? 'active' : ''}}" 
          bindtap="onGenderSelect"
          data-gender="男"
        >
          <text class="gender-icon">♂</text>
          <text class="gender-text">男</text>
        </view>
        <view 
          class="gender-option {{userInfo.gender === '女' ? 'active' : ''}}" 
          bindtap="onGenderSelect"
          data-gender="女"
        >
          <text class="gender-icon">♀</text>
          <text class="gender-text">女</text>
        </view>
      </view>
    </view>

    <!-- 年龄 -->
    <view class="form-item" bindtap="onAgeSelect">
      <text class="form-label">年龄</text>
      <view class="form-value">
        <text class="value-text">{{userInfo.age ? userInfo.age + '岁' : '请选择年龄'}}</text>
        <text class="arrow-icon">›</text>
      </view>
    </view>

    <!-- 手机号 -->
    <view class="form-item disabled">
      <text class="form-label">手机号</text>
      <view class="form-value">
        <text class="value-text">{{userInfo.phone}}</text>
        <text class="bind-tip">已绑定</text>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-section">
    <view class="save-btn" bindtap="onSave">保存</view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-tip">
    <text class="tip-text">完善个人资料有助于获得更好的服务体验</text>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>

<!-- 年龄选择弹窗 -->
<view class="modal-mask" wx:if="{{showAgeModal}}" bindtap="onCloseAgeModal"></view>
<view class="age-modal" wx:if="{{showAgeModal}}">
  <view class="modal-header">
    <text class="modal-title">选择年龄</text>
    <text class="modal-close" bindtap="onCloseAgeModal">✕</text>
  </view>
  <view class="age-list">
    <view 
      class="age-item {{userInfo.age === item ? 'active' : ''}}" 
      wx:for="{{ageList}}" 
      wx:key="*this"
      bindtap="onAgeConfirm"
      data-age="{{item}}"
    >
      <text class="age-text">{{item}}岁</text>
      <text class="check-icon" wx:if="{{userInfo.age === item}}">✓</text>
    </view>
  </view>
</view>
