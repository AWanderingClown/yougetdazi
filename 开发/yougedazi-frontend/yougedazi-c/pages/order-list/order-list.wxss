/* pages/order-list/order-list.wxss */

page {
  --primary-color: #667eea;
  --primary-dark: #764ba2;
  --secondary-color: #f093fb;
  --bg-color: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #eeeeee;
  --female-color: #f093fb;
  --male-color: #667eea;
  --price-color: #e74c3c;
  
  background-color: var(--bg-color);
}

.container {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  position: relative;
}

/* 背景装饰 */
.bg-shape {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  opacity: 0.4;
}

.shape-1 {
  width: 250rpx;
  height: 250rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(102, 126, 234, 0.02) 100%);
  border-radius: 60% 40% 70% 30% / 40% 60% 30% 70%;
  top: 200rpx;
  right: -80rpx;
  transform: rotate(-15deg);
}

.shape-2 {
  width: 150rpx;
  height: 300rpx;
  background: linear-gradient(180deg, rgba(255, 107, 157, 0.08) 0%, rgba(255, 107, 157, 0.02) 100%);
  border-radius: 40% 60% 70% 30% / 60% 30% 70% 40%;
  top: 500rpx;
  left: -50rpx;
  transform: rotate(20deg);
}

.shape-3 {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(45deg, rgba(118, 75, 162, 0.1) 0%, rgba(118, 75, 162, 0.02) 100%);
  border-radius: 70% 30% 50% 50% / 30% 70% 50% 50%;
  bottom: 300rpx;
  right: -40rpx;
  transform: rotate(-10deg);
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(238, 238, 238, 0.8);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

.tab-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: var(--price-color);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 8rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx 24rpx;
  position: relative;
  z-index: 1;
}

.order-card {
  background: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  overflow: hidden;
}

/* 状态色条 */
.card-status-strip {
  height: 8rpx;
}

.card-status-strip.status-warning {
  background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
}

.card-status-strip.status-primary {
  background: linear-gradient(135deg, #7d67ea 0%, #9a59b8 100%);
}

.card-status-strip.status-success {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.card-status-strip.status-secondary {
  background: linear-gradient(135deg, #9ca3af 0%, #d1d5db 100%);
}

.card-status-strip.status-info {
  background: linear-gradient(135deg, #3b82f6 0%, #7d67ea 100%);
}

/* 卡片内容区 */
.card-content {
  padding: 24rpx 28rpx 28rpx;
}

/* 订单头部 */
.order-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.companion-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.companion-info {
  flex: 1;
  min-width: 0;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.companion-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.gender-tag {
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
}

.gender-tag.female {
  background: #FCE4EC;
  color: var(--female-color);
}

.gender-tag.male {
  background: #E3F2FD;
  color: var(--male-color);
}

.service-row {
  display: flex;
  align-items: center;
}

.service-name {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-right: 16rpx;
}

.service-duration {
  font-size: 24rpx;
  color: var(--text-light);
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 状态标签 */
.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.status-warning {
  background: #FFF3E0;
  color: #FF9800;
}

.status-primary {
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
}

.status-success {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-grey {
  background: #f5f5f5;
  color: var(--text-light);
}

/* 订单信息 */
.order-info {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-top: 1rpx dashed var(--border-color);
  border-bottom: 1rpx dashed var(--border-color);
  margin-bottom: 20rpx;
}

.info-left {
  flex: 1;
  min-width: 0;
}

/* 右侧金额块，垂直居中于两行信息之间 */
.info-price-block {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-light);
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}

.info-value.address {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 订单底部 */
.order-footer {
  margin-top: 4rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-right: 8rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--price-color);
}

/* 操作按钮 */
.action-btns {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 68rpx;
  border-radius: 34rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-sizing: border-box;
}

.btn.default {
  background: #ffffff;
  color: #555555;
  border: 1rpx solid #e0e0e0;
}

.btn.secondary {
  background: #f5f5f5;
  color: var(--text-secondary);
  border-radius: 34rpx;
}

.btn.primary {
  background: linear-gradient(135deg, #7d67ea 0%, #9a59b8 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(125, 103, 234, 0.3);
}

.btn.info {
  background: linear-gradient(135deg, #5B8FF9 0%, #FF6B9D 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(91, 143, 249, 0.25);
}

/* 展开详情区域 */
.order-detail-expand {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed var(--border-color);
  animation: expandIn 0.3s ease;
}

@keyframes expandIn {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.expand-section {
  margin-bottom: 24rpx;
}

.expand-section:last-child {
  margin-bottom: 0;
}

.expand-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* 模拟地图容器 */
.map-container {
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f5f5f5;
}

.map-mock {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.map-bg {
  flex: 1;
  position: relative;
  background: linear-gradient(135deg, #e8f4f8 0%, #f0e8f4 50%, #f8e8f0 100%);
  overflow: hidden;
}

/* 地图网格线 */
.map-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    linear-gradient(rgba(123, 104, 238, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(123, 104, 238, 0.1) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
}

/* 路线 */
.map-route {
  position: absolute;
  top: 50%;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  transform: translateY(-50%) rotate(-15deg);
  border-radius: 2rpx;
}

.map-route::before {
  content: '';
  position: absolute;
  right: -10rpx;
  top: 50%;
  transform: translateY(-50%);
  border: 8rpx solid transparent;
  border-left: 12rpx solid var(--secondary-color);
}

/* 位置标记 */
.location-marker {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-marker {
  right: 15%;
  top: 30%;
}

.companion-marker {
  left: 20%;
  top: 60%;
}

.marker-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #4CAF50;
  border: 4rpx solid #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

.marker-dot.companion {
  background: var(--primary-color);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 0 0 rgba(123, 104, 238, 0.4);
  }
  50% {
    transform: scale(1.1);
    box-shadow: 0 0 0 10rpx rgba(123, 104, 238, 0);
  }
}

.marker-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: rgba(255,255,255,0.9);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 地图信息 */
.map-info {
  padding: 16rpx 20rpx;
  background: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.map-distance {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.map-eta {
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 倒计时显示 */
.timer-display {
  margin-bottom: 20rpx;
}

.timer-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(123, 104, 238, 0.1) 0%, rgba(255, 107, 157, 0.05) 100%);
  border-radius: 16rpx;
}

.timer-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--price-color);
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
  letter-spacing: 4rpx;
}

.timer-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

/* 进度条 */
.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-text {
  font-size: 26rpx;
  color: var(--primary-color);
  font-weight: 500;
}

.progress-time {
  font-size: 24rpx;
  color: var(--text-light);
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  gap: 20rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: rgba(123, 104, 238, 0.06);
  border-radius: 16rpx;
}

.quick-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.quick-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 展开/收起切换 */
.expand-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
  margin-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
}

.toggle-text {
  font-size: 24rpx;
  color: var(--text-light);
  margin-right: 8rpx;
}

.toggle-icon {
  font-size: 20rpx;
  color: var(--text-light);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-emoji {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 28rpx 100rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  min-width: 280rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.safe-area-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 悬赏订单样式 ========== */

/* 紫色状态标签 */
.status-purple {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%);
  color: #764ba2;
  font-weight: 600;
}

/* 悬赏图标 */
.reward-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.reward-icon-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 悬赏名称 */
.reward-name {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 悬赏标签 */
.reward-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border: 1rpx solid rgba(102, 126, 234, 0.2);
}

.reward-tag-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #764ba2;
}


/* 抢单搭子标签 */
.companion-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 8rpx 0;
}

.companion-tags .tag-item {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 20rpx;
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  margin-left: 12rpx;
  font-weight: 500;
}

/* 悬赏描述 */
.reward-description {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  border-left: 4rpx solid #667eea;
}

.desc-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 抢单倒计时区域 */
.grab-countdown-section {
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.1);
}

.grab-countdown-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 16rpx;
}

.grab-countdown-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #764ba2;
  font-family: 'DIN Alternate', 'Helvetica Neue', monospace;
  letter-spacing: 4rpx;
}

.grab-countdown-label {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

/* 抢单进度条 */
.grab-progress-bar {
  height: 8rpx;
  background: rgba(118, 75, 162, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.grab-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 4rpx;
  transition: width 1s linear;
}


/* 分享按钮特殊样式 */
.btn.share {
  background: linear-gradient(135deg, #07C160 0%, #05a350 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}
