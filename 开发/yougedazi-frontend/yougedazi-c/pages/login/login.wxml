<view class="container">
  <!-- 顶部品牌区域 -->
  <view class="brand-section">
    <view class="logo-circle">
      <text class="logo-text">PP</text>
    </view>
    <text class="app-name">有个搭子</text>
    <text class="app-slogan">你的专属陪伴平台</text>
  </view>

  <!-- 登录按钮区域 -->
  <view class="login-section">
    <button class="btn-wechat" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <text class="wechat-icon">微信</text>
      <text class="btn-text">微信一键登录</text>
    </button>

    <view class="phone-login" bindtap="onPhoneLogin">
      <text class="phone-text">手机号登录</text>
    </view>
  </view>

  <!-- 手机号登录表单 -->
  <view class="phone-form" wx:if="{{showPhoneForm}}">
    <view class="form-mask" bindtap="onClosePhoneForm"></view>
    <view class="form-content">
      <view class="form-header">
        <text class="form-title">手机号登录</text>
        <text class="form-close" bindtap="onClosePhoneForm">×</text>
      </view>

      <view class="input-group">
        <text class="input-prefix">+86</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
      </view>

      <view class="input-group" wx:if="{{phoneSent}}">
        <input class="input-field" type="number" maxlength="6" placeholder="请输入验证码" bindinput="onCodeInput" value="{{code}}" />
        <view class="code-btn {{countdown > 0 ? 'disabled' : ''}}" bindtap="onResendCode">
          {{countdown > 0 ? countdown + 's' : '重新获取'}}
        </view>
      </view>

      <button class="btn-submit" wx:if="{{!phoneSent}}" disabled="{{phone.length !== 11}}" bindtap="onSendCode">获取验证码</button>
      <button class="btn-submit" wx:if="{{phoneSent}}" disabled="{{code.length !== 6}}" bindtap="onPhoneConfirm">登录</button>
    </view>
  </view>

  <!-- 底部协议 -->
  <view class="agreement-section">
    <text class="agreement-text">登录即表示同意</text>
    <text class="agreement-link" bindtap="onUserAgreement">《用户协议》</text>
    <text class="agreement-text">和</text>
    <text class="agreement-link" bindtap="onPrivacyPolicy">《隐私政策》</text>
  </view>
</view>
