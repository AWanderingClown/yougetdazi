page {
  background-color: #f5f5f5;
}

.container {
  padding: 40rpx 30rpx;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
}

.step-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.input-group {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx 0;
  margin-bottom: 40rpx;
}

.input-prefix {
  font-size: 32rpx;
  color: #333;
  margin-right: 20rpx;
  font-weight: 500;
}

.input-field {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.code-input {
  letter-spacing: 8rpx;
}

.code-btn {
  font-size: 26rpx;
  color: #7B68EE;
  white-space: nowrap;
  padding-left: 20rpx;
}

.code-btn.disabled {
  color: #999;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B89F5 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 44rpx;
  border: none;
  margin-top: 20rpx;
}

.btn-primary[disabled] {
  background: #ccc;
  color: #fff;
}
