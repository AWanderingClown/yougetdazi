page {
  background-color: #fff;
}

.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #7B68EE;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 更新时间 */
.update-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 内容区域 - rich-text 内的样式需要通过 nodes 的 style 属性控制 */
.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

/* 加载失败 */
.error {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.btn-retry {
  font-size: 28rpx;
  color: #7B68EE;
  background: none;
  border: 1rpx solid #7B68EE;
  border-radius: 30rpx;
  padding: 10rpx 40rpx;
  line-height: 1.8;
}
