.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100px, #f5f5f5 100px);
  padding: 0 30rpx 40rpx;
}

.header {
  padding: 40rpx 20rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  min-height: 88rpx;
}

.form-item.block {
  flex-direction: column;
  align-items: flex-start;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  width: 180rpx;
  flex-shrink: 0;
}

.form-label.required::after {
  content: '*';
  color: #ff6b6b;
  margin-left: 4rpx;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.placeholder {
  color: #ccc;
  font-size: 28rpx;
}

.placeholder.hidden {
  display: none;
}

.value-text {
  font-size: 28rpx;
  color: #333;
  margin-right: 16rpx;
}

.icon-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: 300;
}

.form-input-group {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.form-input {
  text-align: right;
  font-size: 28rpx;
  color: #333;
  height: 60rpx;
  min-width: 120rpx;
}

.price-input, .duration-input {
  width: 160rpx;
}

.input-unit {
  font-size: 26rpx;
  color: #666;
  margin-left: 12rpx;
}

.count-selector {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 20rpx;
}

.count-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.count-btn.disabled {
  background: #e0e0e0;
  color: #999;
}

.count-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  min-width: 80rpx;
  text-align: center;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 10rpx 30rpx;
}

.form-textarea {
  width: 100%;
  height: 180rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.textarea-count {
  width: 100%;
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.radio-group {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.radio-item {
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.radio-item.active {
  background: rgba(102, 126, 234, 0.1);
  color: #667eea;
  border-color: #667eea;
}

.amount-preview {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 16rpx;
  margin: 30rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.amount-value {
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.amount-number {
  font-size: 48rpx;
  color: #ff6b6b;
  font-weight: 700;
}

.btn-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.submit-btn {
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.submit-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.submit-btn:active {
  transform: scale(0.98);
}

.submit-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 弹窗样式 */
.popup, .modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.popup.show, .modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.popup-content, .modal-content {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.3s;
}

.popup.show .popup-content, .modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
}

/* 底部弹窗 */
.popup-content {
  top: auto;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  transform: translateY(100%);
  border-radius: 32rpx 32rpx 0 0;
}

.popup.show .popup-content {
  transform: translateY(0);
}

.popup-header, .modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title, .modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.popup-close, .modal-close {
  font-size: 44rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

.popup-body {
  max-height: 600rpx;
}

.service-list {
  padding: 20rpx 30rpx;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.service-item:last-child {
  border-bottom: none;
}

.service-item.active {
  color: #667eea;
}

.service-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.service-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.service-item.active .service-name {
  color: #667eea;
  font-weight: 500;
}

.service-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #667eea;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
}

.service-check.show {
  opacity: 1;
}

/* 支付弹窗 */
.modal-body {
  padding: 40rpx;
}

.pay-amount {
  text-align: center;
  margin-bottom: 40rpx;
}

.pay-label {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 16rpx;
}

.pay-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.pay-symbol {
  font-size: 40rpx;
  color: #ff6b6b;
  font-weight: 600;
}

.pay-number {
  font-size: 64rpx;
  color: #ff6b6b;
  font-weight: 700;
}

.pay-info {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.pay-item {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.pay-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #f0f0f0;
}

.modal-btn.confirm {
  color: #667eea;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
}

/* 成功弹窗 */
.success-content {
  padding: 60rpx 40rpx;
  text-align: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.countdown-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.countdown-label {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.countdown-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #667eea;
  display: block;
  margin-bottom: 12rpx;
}

.countdown-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.success-footer {
  display: flex;
  justify-content: center;
}

.success-btn {
  padding: 24rpx 80rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.success-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}
