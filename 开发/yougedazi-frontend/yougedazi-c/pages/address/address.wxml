<!-- pages/address/address.wxml -->
<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="nav-title">地址管理</view>
    <view class="right-btn" bindtap="addAddress">+</view>
  </view>

  <!-- 地址列表 -->
  <view class="address-list">
    <view 
      class="address-item {{item.isDefault ? 'default' : ''}}"
      wx:for="{{addressList}}"
      wx:key="id"
      bindtap="selectAddress"
      data-id="{{item.id}}"
    >
      <view class="address-info">
        <view class="user-row">
          <text class="user-name">{{item.name}}</text>
          <text class="user-phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
        </view>
        <view class="address-row">
          <text class="address-text">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</text>
        </view>
      </view>
      <view class="edit-btn" catchtap="editAddress" data-id="{{item.id}}">
        <text>编辑</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{addressList.length === 0}}">
      <text class="empty-icon">📍</text>
      <text class="empty-text">暂无收货地址</text>
      <text class="empty-desc">点击下方按钮添加地址</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-section">
    <view class="add-btn" bindtap="addAddress">
      <text>+ 新建地址</text>
    </view>
  </view>
</view>
