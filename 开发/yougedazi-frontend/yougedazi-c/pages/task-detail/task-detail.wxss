/* pages/task-detail/task-detail.wxss */

page {
  background-color: #f5f5f5;
}

.container {
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 顶部渐变背景 */
.header-gradient {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  text-align: center;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 16rpx;
}

.header-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 任务卡片 */
.task-card {
  background: #ffffff;
  border-radius: 24rpx;
  margin: -60rpx 30rpx 30rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx dashed #eee;
}

.service-type {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.price-tag {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

/* 任务信息 */
.task-info {
  margin-bottom: 30rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 任务描述 */
.task-description {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #667eea;
}

.desc-label {
  font-size: 26rpx;
  color: #667eea;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 任务状态 */
.task-status {
  text-align: center;
  padding-top: 20rpx;
  border-top: 2rpx dashed #eee;
}

.status-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(102, 126, 234, 0.2);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作区 */
.bottom-section {
  padding: 0 30rpx;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 193, 7, 0.1);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #f57c00;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 30rpx 0;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #ffffff;
  color: #667eea;
  font-size: 30rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 48rpx;
  border: 2rpx solid #667eea;
}

.btn-secondary::after {
  border: none;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 40rpx;
}
