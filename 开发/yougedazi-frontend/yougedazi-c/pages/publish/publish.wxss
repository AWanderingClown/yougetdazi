.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部区域 */
.hero-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx 80rpx;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 模式选择卡片 */
.mode-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 30rpx;
  margin-top: -40rpx;
}

.mode-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.mode-card:active {
  transform: scale(0.98);
  background: #fafafa;
}

.mode-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.direct-icon {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.reward-icon {
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
}

.mode-content {
  flex: 1;
}

.mode-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.mode-desc {
  font-size: 26rpx;
  color: #999;
}

.mode-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #ff6b6b;
  background: rgba(255, 107, 107, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-top: 10rpx;
}

.mode-arrow {
  font-size: 44rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  padding-left: 16rpx;
}

/* 底部提示 */
.tips {
  text-align: center;
  padding: 40rpx 40rpx 0;
}

.tips-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
