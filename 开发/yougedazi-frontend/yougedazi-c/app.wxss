/**app.wxss - 有个搭子 全局样式**/

/* 全局变量 */
page {
  --primary-color: #7B68EE;
  --primary-light: #9B89F5;
  --primary-dark: #5A4ACF;
  --secondary-color: #FF6B9D;
  --bg-color: #f8f8f8;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --border-color: #eeeeee;
  --male-color: #4A90E2;
  --female-color: #FF6B9D;
  --price-color: #FF4D4F;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #FF4D4F;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 4rpx 20rpx rgba(123, 104, 238, 0.15);
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  background-color: var(--bg-color);
}

/* 重置样式 */
view, text, image, scroll-view, swiper, swiper-item, button, input, textarea {
  box-sizing: border-box;
}

/* 安全区域适配 */
.safe-area-bottom {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.safe-area-top {
  padding-top: env(safe-area-inset-top);
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: var(--shadow);
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);
  color: #ffffff;
}

.btn-default {
  background: #f0f0f0;
  color: var(--text-primary);
}

.btn-outline {
  background: #ffffff;
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
}

.btn-disabled {
  background: #cccccc;
  color: #ffffff;
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-right: 12rpx;
}

.tag-primary {
  background: rgba(123, 104, 238, 0.1);
  color: var(--primary-color);
}

/* 价格样式 */
.price {
  color: var(--price-color);
  font-weight: 700;
}

.price-symbol {
  font-size: 24rpx;
}

.price-value {
  font-size: 36rpx;
}

/* 文本省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 20rpx 0;
}

.divider-v {
  width: 1rpx;
  height: 40rpx;
  background: var(--border-color);
  margin: 0 20rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

/* 浮动按钮 */
.float-btn {
  position: fixed;
  right: 40rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.4);
  z-index: 100;
}

/* 角标 */
.badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: var(--price-color);
  color: #ffffff;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
