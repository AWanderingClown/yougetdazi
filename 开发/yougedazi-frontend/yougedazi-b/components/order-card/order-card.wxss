/* components/order-card/order-card.wxss */

/* ========== 订单卡片 ========== */
.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(123, 104, 238, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.order-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(123, 104, 238, 0.12);
}

/* 卡片头部：用户信息 + 价格 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f0e6ff;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 6rpx;
}

.user-meta {
  font-size: 24rpx;
  color: #9CA3AF;
}

.price-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.price-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #7B68EE;
  font-family: DIN Alternate, DIN, Arial;
}

/* 卡片中部：订单详情 */
.card-body {
  padding: 20rpx 0;
  border-top: 1rpx solid #F3F4F6;
  border-bottom: 1rpx solid #F3F4F6;
}

.detail-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  width: 32rpx;
  text-align: center;
}

.detail-label {
  font-size: 24rpx;
  color: #9CA3AF;
  width: 64rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #4B5563;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 卡片底部：状态标签 + 操作按钮 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

/* 状态标签 */
.status-tag {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-pending_accept {
  background: #FEF3C7;
  color: #F59E0B;
}

.tag-accepted {
  background: #EDE9FE;
  color: #7C3AED;
}

.tag-serving {
  background: #F0E6FF;
  color: #7B68EE;
}

.tag-completed {
  background: #D1FAE5;
  color: #10B981;
}

.tag-cancelled {
  background: #FEE2E2;
  color: #EF4444;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-action {
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary {
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
}

.btn-secondary {
  background: #F0E6FF;
  color: #7B68EE;
}

.btn-outline {
  background: #ffffff;
  color: #7B68EE;
  border: 2rpx solid #7B68EE;
}

/* 倒计时 */
.countdown {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.countdown-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #EF4444;
  margin-bottom: 8rpx;
}

.countdown-bar {
  width: 100rpx;
  height: 6rpx;
  background: #FEE2E2;
  border-radius: 3rpx;
  overflow: hidden;
}

.countdown-progress {
  height: 100%;
  background: #EF4444;
  border-radius: 3rpx;
  transition: width 1s linear;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 40rpx;
}

.empty-action {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  border-radius: 44rpx;
}

.empty-action-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
}