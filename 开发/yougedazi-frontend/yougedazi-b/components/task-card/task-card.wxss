/* components/task-card/task-card.wxss */

/* ========== 任务卡片 ========== */
.task-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(123, 104, 238, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.task-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(123, 104, 238, 0.12);
}

/* ========== 卡片头部：服务类型 ========== */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.service-info {
  display: flex;
  align-items: center;
}

.service-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.service-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.tag-group {
  display: flex;
  gap: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-new {
  background: #F0E6FF;
  color: #7B68EE;
}

.tag-urgent {
  background: #FEE2E2;
  color: #EF4444;
}

/* ========== 卡片中部：价格信息 ========== */
.card-body {
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.price-symbol {
  font-size: 24rpx;
  font-weight: 600;
  color: #7B68EE;
}

.price-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #7B68EE;
  font-family: DIN Alternate, DIN, Arial;
}

.price-unit {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-left: 4rpx;
}

.task-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  background: #F9FAFB;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.detail-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.detail-value {
  font-size: 24rpx;
  color: #4B5563;
}

/* ========== 卡片底部：用户信息 + 抢单按钮 ========== */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #F0E6FF;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 26rpx;
  color: #4B5563;
}

.user-tags {
  display: flex;
  gap: 8rpx;
  margin-top: 4rpx;
}

.user-tag {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  background: #F0E6FF;
  color: #7B68EE;
  border-radius: 4rpx;
}

.user-tag.regular {
  background: #D1FAE5;
  color: #10B981;
}

/* ========== 抢单按钮 ========== */
.grab-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  color: #ffffff;
  border-radius: 32rpx;
  font-size: 26rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.3);
}

.grab-btn:active {
  transform: scale(0.96);
}

.grab-btn.disabled {
  background: #E5E7EB;
  color: #9CA3AF;
  box-shadow: none;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
}