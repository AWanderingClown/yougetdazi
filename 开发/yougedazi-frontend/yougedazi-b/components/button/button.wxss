/* components/button/button.wxss */

/* ========== 按钮变量 ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  font-weight: 500;
  border-radius: 44rpx;
  transition: all 0.15s ease;
  box-sizing: border-box;
}

/* ========== 尺寸 ========== */
.btn-large {
  height: 96rpx;
  padding: 0 48rpx;
  font-size: 32rpx;
  border-radius: 48rpx;
}

.btn-medium {
  height: 80rpx;
  padding: 0 36rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.btn-small {
  height: 64rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
}

.btn-mini {
  height: 48rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  border-radius: 24rpx;
}

/* ========== 类型 ========== */
.btn-primary {
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.3);
}

.btn-primary.btn-hover {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(123, 104, 238, 0.2);
}

.btn-secondary {
  background: #F0E6FF;
  color: #7B68EE;
}

.btn-secondary.btn-hover {
  background: #E0D6FF;
}

.btn-outline {
  background: #ffffff;
  color: #7B68EE;
  border: 2rpx solid #7B68EE;
}

.btn-outline.btn-hover {
  background: #F0E6FF;
}

.btn-text {
  background: transparent;
  color: #7B68EE;
}

.btn-text.btn-hover {
  opacity: 0.7;
}

/* ========== 禁用状态 ========== */
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ========== 块级按钮 ========== */
.btn-block {
  display: flex;
  width: 100%;
}

/* ========== 加载动画 ========== */
.btn-loading {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: btn-spin 0.8s linear infinite;
  margin-right: 12rpx;
}

.btn-secondary .btn-loading,
.btn-outline .btn-loading,
.btn-text .btn-loading {
  border-color: rgba(123, 104, 238, 0.3);
  border-top-color: #7B68EE;
}

@keyframes btn-spin {
  to { transform: rotate(360deg); }
}