/* components/modal/modal.wxss */

/* ========== 遮罩层 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

/* ========== 弹窗容器 ========== */
.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  max-width: 90%;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1001;
}

.modal-container.show {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
  visibility: visible;
}

/* ========== 弹窗内容 ========== */
.modal-content {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

/* ========== 头部 ========== */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 30rpx 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.modal-close {
  font-size: 44rpx;
  color: #9CA3AF;
  line-height: 1;
}

/* ========== 内容区 ========== */
.modal-body {
  padding: 20rpx 30rpx 30rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.6;
  display: block;
}

/* ========== 底部按钮 ========== */
.modal-footer {
  display: flex;
  border-top: 1rpx solid #F3F4F6;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn-cancel {
  color: #4B5563;
  border-right: 1rpx solid #F3F4F6;
}

.modal-btn-cancel:active {
  background: #F9FAFB;
}

.modal-btn-confirm {
  color: #7B68EE;
}

.modal-btn-confirm:active {
  background: #F0E6FF;
}