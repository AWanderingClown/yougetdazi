/* pages/services/services.wxss - 服务项目样式 */

.page-services {
  min-height: 100vh;
  background: #F5F3FF;
  display: flex;
  flex-direction: column;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 修改/取消按钮（移至内容区标题行） */
.section-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.modify-btn {
  font-size: 26rpx;
  color: #7B68EE;
  background: rgba(123, 104, 238, 0.1);
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
}

.modify-btn.cancel {
  color: #9CA3AF;
  background: #F3F4F6;
}

.modify-btn.auditing {
  color: #D97706;
  background: rgba(245, 158, 11, 0.1);
}

/* ========== 审核状态横幅 ========== */
.audit-banner {
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.audit-banner.pending {
  background: linear-gradient(135deg, #FFFBEB, #FFF7ED);
  border: 2rpx solid #FDE68A;
}

.audit-banner.approved {
  background: linear-gradient(135deg, #ECFDF5, #F0FDF4);
  border: 2rpx solid #A7F3D0;
}

.audit-banner.rejected {
  background: linear-gradient(135deg, #FFF5F5, #FFF1F2);
  border: 2rpx solid #FECACA;
}

.audit-banner-icon {
  font-size: 44rpx;
  flex-shrink: 0;
  line-height: 1;
}

.audit-banner-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.audit-banner-title {
  font-size: 28rpx;
  font-weight: 600;
}

.audit-banner.pending .audit-banner-title { color: #D97706; }
.audit-banner.approved .audit-banner-title { color: #059669; }
.audit-banner.rejected .audit-banner-title { color: #DC2626; }

.audit-banner-desc {
  font-size: 24rpx;
  line-height: 1.5;
}

.audit-banner.pending .audit-banner-desc { color: #92400E; }
.audit-banner.approved .audit-banner-desc { color: #065F46; }
.audit-banner.rejected .audit-banner-desc { color: #991B1B; }

/* ========== 内容区 ========== */
.content {
  flex: 1;
  padding: 28rpx 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-label-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.section-hint {
  font-size: 22rpx;
  color: #9B8FEE;
  font-weight: 400;
}

.section-count {
  font-size: 26rpx;
  color: #7B68EE;
  background: rgba(123, 104, 238, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
}

/* ========== 服务宫格 ========== */
.service-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.service-item {
  width: calc((100% - 40rpx) / 3);
  height: 200rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  position: relative;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* ---- 查看模式：已开通 = 绿色（可接单） ---- */
.service-item.active {
  background: linear-gradient(145deg, #10B981, #059669);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.35);
}

/* 已开通右上角"可接单"角标 */
.service-item.active::after {
  content: '可接单';
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 18rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* ---- 查看模式：未开通 = 灰色弱化 ---- */
.service-item.dim {
  opacity: 0.35;
}

/* ---- 编辑模式：可点击 ---- */
.service-item.editable {
  border: 2rpx solid #E5E7EB;
  opacity: 1;
  cursor: pointer;
}

/* 编辑模式取消"可接单"角标 */
.service-item.editable::after {
  display: none;
}

/* ---- 编辑模式：未选中 = 白底 + 虚线边框，传达"可点击选择"语义 ---- */
.service-item.editable.unselected {
  background: #FFFFFF;
  border: 3rpx dashed #C4B8F5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  opacity: 0.85;
}

.service-item.editable.unselected:active {
  transform: scale(0.95);
  background: #F3F0FF;
  border-color: #7B68EE;
  border-style: dashed;
  box-shadow: 0 4rpx 16rpx rgba(123, 104, 238, 0.18);
  opacity: 1;
}

/* ---- 编辑模式：已选中 = 紫色渐变 + 实线边框 + 强阴影 ---- */
.service-item.editable.selected {
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  border: 3rpx solid #6A55D9;
  box-shadow: 0 12rpx 36rpx rgba(123, 104, 238, 0.5), 0 2rpx 8rpx rgba(123, 104, 238, 0.3);
  opacity: 1;
}

.service-item.editable.selected:active {
  transform: scale(0.93);
  box-shadow: 0 6rpx 20rpx rgba(123, 104, 238, 0.4);
}

/* 右上角勾选标记（编辑模式） */
.item-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #ffffff, #F0F0F0);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  animation: checkBounce 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.check-icon {
  font-size: 24rpx;
  color: #7B68EE;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 勾选标记的弹入动画 */
@keyframes checkBounce {
  0% {
    transform: scale(0) rotate(-45deg);
    opacity: 0;
  }
  50% {
    transform: scale(1.15);
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

/* 图标 — 改为 image */
.item-icon {
  width: 64rpx;
  height: 64rpx;
}

.item-name {
  font-size: 25rpx;
  font-weight: 500;
  color: #374151;
  text-align: center;
}

.item-price {
  font-size: 20rpx;
  color: #9CA3AF;
  margin-top: -6rpx;
}

.service-item.active .item-price,
.service-item.editable.selected .item-price {
  color: rgba(255, 255, 255, 0.8);
}

/* 高亮状态文字变白 + 图标反色 */
.service-item.active .item-name,
.service-item.editable.selected .item-name {
  color: #fff;
}

.service-item.active .item-icon,
.service-item.editable.selected .item-icon {
  filter: brightness(0) invert(1);
}

/* ========== 编辑提示 ========== */
.tips-box {
  margin-top: 36rpx;
  background: rgba(123, 104, 238, 0.07);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-line {
  font-size: 25rpx;
  color: #7B68EE;
  line-height: 1.6;
}

/* ========== 提交按钮 ========== */
.submit-bar {
  padding: 20rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #F5F3FF;
}

.submit-btn {
  height: 96rpx;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.4);
  transition: transform 0.15s ease;
}

.submit-btn:active {
  transform: scale(0.97);
}
