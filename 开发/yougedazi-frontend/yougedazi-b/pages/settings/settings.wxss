/* pages/settings/settings.wxss - 设置页面样式 */

/* ===================== 页面容器 ===================== */
.page-settings {
  min-height: 100vh;
  background: #F2F3F8;
  display: flex;
  flex-direction: column;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* ===================== 滚动容器 ===================== */
.settings-scroll {
  flex: 1;
  height: calc(100vh - 220rpx);
  padding-top: 8rpx;
}

/* ===================== 分组标签 ===================== */
.section-label {
  font-size: 22rpx;
  color: #9FA3B4;
  font-weight: 500;
  letter-spacing: 1rpx;
  padding: 28rpx 36rpx 12rpx;
  text-transform: uppercase;
}

/* ===================== 设置分组卡片 ===================== */
.settings-group {
  margin: 0 24rpx 8rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(102, 126, 234, 0.07), 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
}

/* ===================== 设置行 ===================== */
.settings-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  background: #fff;
  min-height: 112rpx;
  box-sizing: border-box;
}

.item-hover {
  background: #F7F5FF;
}

.item-hover-none {
  background: #fff;
}

/* 分隔线 */
.item-divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent 80rpx, #F0F0F5 80rpx, #F0F0F5 calc(100% - 0rpx), transparent 100%);
  margin: 0 0 0 88rpx;
}

/* ===================== 图标容器 ===================== */
.item-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 34rpx;
  line-height: 1;
}

/* 图标色板 */
.icon-purple {
  background: linear-gradient(135deg, #EDE9FF 0%, #DDD5FF 100%);
}

.icon-blue {
  background: linear-gradient(135deg, #E0EEFF 0%, #C7DBFF 100%);
}

.icon-teal {
  background: linear-gradient(135deg, #D9F7F0 0%, #B8EDE4 100%);
}

.icon-orange {
  background: linear-gradient(135deg, #FFF0E0 0%, #FFE0BC 100%);
}

.icon-green {
  background: linear-gradient(135deg, #E2F8E8 0%, #C6EDD0 100%);
}

.icon-violet {
  background: linear-gradient(135deg, #F0E8FF 0%, #E2D1FF 100%);
}

.icon-slate {
  background: linear-gradient(135deg, #F0F2FA 0%, #E2E6F4 100%);
}

.icon-pink {
  background: linear-gradient(135deg, #FFE8F2 0%, #FFD0E6 100%);
}

/* ===================== 文字区域 ===================== */
.item-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.item-label {
  font-size: 29rpx;
  color: #1A1A2E;
  font-weight: 500;
  line-height: 1.3;
}

.item-desc {
  font-size: 22rpx;
  color: #ABABBB;
  line-height: 1.3;
}

/* ===================== 右侧区域 ===================== */
.item-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-arrow {
  font-size: 32rpx;
  color: #C8C8D8;
  line-height: 1;
  margin-right: -4rpx;
}

/* 缓存标签 */
.cache-badge {
  background: linear-gradient(135deg, #FFF0E0, #FFE4C4);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

.cache-badge-text {
  font-size: 22rpx;
  color: #E07B00;
  font-weight: 500;
}

/* 版本最新标签 */
.version-tag {
  background: linear-gradient(135deg, #DDFAF0, #C0F2E2);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

.version-tag-text {
  font-size: 22rpx;
  color: #14A86A;
  font-weight: 500;
}

/* Switch 开关 */
.setting-switch {
  transform: scale(0.82);
  transform-origin: right center;
}

/* ===================== 退出登录 ===================== */
.logout-section {
  margin: 40rpx 24rpx 16rpx;
}

.logout-btn {
  height: 96rpx;
  background: #fff;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1.5rpx solid #FFCDD5;
  box-shadow: 0 4rpx 20rpx rgba(239, 68, 68, 0.08);
  transition: all 0.2s ease;
}

.logout-btn-hover {
  background: #FFF5F6;
  box-shadow: 0 6rpx 24rpx rgba(239, 68, 68, 0.14);
  transform: translateY(-1rpx);
}

.logout-btn-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #EF4444;
  letter-spacing: 2rpx;
}

/* ===================== 底部信息 ===================== */
.footer-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 28rpx;
  gap: 10rpx;
}

.footer-logo-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.footer-brand {
  font-size: 26rpx;
  font-weight: 700;
  color: #C0C4D6;
  letter-spacing: 3rpx;
}

.footer-copyright {
  font-size: 22rpx;
  color: #CBCFDF;
}

.footer-version {
  font-size: 20rpx;
  color: #D8DBE8;
}

.footer-safe-area {
  height: env(safe-area-inset-bottom);
  min-height: 20rpx;
}
