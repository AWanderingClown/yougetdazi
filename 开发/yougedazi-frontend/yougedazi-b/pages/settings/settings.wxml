<!-- pages/settings/settings.wxml - 设置 -->
<view class="page-settings">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="nav-left" bindtap="goBack">
      <text class="nav-back-icon">‹</text>
    </view>
    <text class="nav-title">设置</text>
    <view class="nav-right"></view>
  </view>

  <!-- 页面滚动内容 -->
  <scroll-view class="settings-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">

    <!-- 分组一：账号与通知 -->
    <view class="section-label">账号与通知</view>
    <view class="settings-group">

      <!-- 账号与安全 -->
      <view class="settings-item" bindtap="goToAccount" hover-class="item-hover">
        <view class="item-icon-wrap icon-purple">
          <view class="item-svg-icon">
            <text class="icon-text">🔐</text>
          </view>
        </view>
        <view class="item-body">
          <text class="item-label">账号与安全</text>
          <text class="item-desc">管理账号信息与登录安全</text>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>

      <view class="item-divider"></view>

      <!-- 消息通知 -->
      <view class="settings-item" hover-class="item-hover-none">
        <view class="item-icon-wrap icon-blue">
          <text class="icon-text">🔔</text>
        </view>
        <view class="item-body">
          <text class="item-label">消息通知</text>
          <text class="item-desc">接收平台消息推送</text>
        </view>
        <view class="item-right">
          <switch
            checked="{{notificationEnabled}}"
            color="#667eea"
            change="toggleNotification"
            class="setting-switch"
          />
        </view>
      </view>

      <view class="item-divider"></view>

      <!-- 接单提醒 -->
      <view class="settings-item" hover-class="item-hover-none">
        <view class="item-icon-wrap icon-teal">
          <text class="icon-text">📲</text>
        </view>
        <view class="item-body">
          <text class="item-label">接单提醒</text>
          <text class="item-desc">有新订单时即时提醒</text>
        </view>
        <view class="item-right">
          <switch
            checked="{{orderReminder}}"
            color="#667eea"
            change="toggleOrderReminder"
            class="setting-switch"
          />
        </view>
      </view>

    </view>

    <!-- 分组二：应用管理 -->
    <view class="section-label">应用管理</view>
    <view class="settings-group">

      <!-- 清除缓存 -->
      <view class="settings-item" bindtap="clearCache" hover-class="item-hover">
        <view class="item-icon-wrap icon-orange">
          <text class="icon-text">🗑️</text>
        </view>
        <view class="item-body">
          <text class="item-label">清除缓存</text>
          <text class="item-desc">当前缓存：{{cacheSize}}</text>
        </view>
        <view class="item-right">
          <view class="cache-badge">
            <text class="cache-badge-text">{{cacheSize}}</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>

      <view class="item-divider"></view>

      <!-- 检查更新 -->
      <view class="settings-item" bindtap="checkUpdate" hover-class="item-hover">
        <view class="item-icon-wrap icon-green">
          <text class="icon-text">⬆️</text>
        </view>
        <view class="item-body">
          <text class="item-label">检查更新</text>
          <text class="item-desc">当前版本 v1.0.0</text>
        </view>
        <view class="item-right">
          <view class="version-tag">
            <text class="version-tag-text">最新</text>
          </view>
          <text class="item-arrow">›</text>
        </view>
      </view>

      <view class="item-divider"></view>

      <!-- 关于有个搭子 -->
      <view class="settings-item" bindtap="aboutUs" hover-class="item-hover">
        <view class="item-icon-wrap icon-violet">
          <text class="icon-text">ℹ️</text>
        </view>
        <view class="item-body">
          <text class="item-label">关于有个搭子</text>
          <text class="item-desc">了解我们的产品与团队</text>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>

    </view>

    <!-- 分组三：法律文件 -->
    <view class="section-label">法律文件</view>
    <view class="settings-group">

      <!-- 用户协议 -->
      <view class="settings-item" bindtap="viewAgreement" hover-class="item-hover">
        <view class="item-icon-wrap icon-slate">
          <text class="icon-text">📋</text>
        </view>
        <view class="item-body">
          <text class="item-label">用户协议</text>
          <text class="item-desc">了解平台服务条款</text>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>

      <view class="item-divider"></view>

      <!-- 隐私政策 -->
      <view class="settings-item" bindtap="viewPrivacy" hover-class="item-hover">
        <view class="item-icon-wrap icon-pink">
          <text class="icon-text">🔒</text>
        </view>
        <view class="item-body">
          <text class="item-label">隐私政策</text>
          <text class="item-desc">了解数据收集与使用说明</text>
        </view>
        <view class="item-right">
          <text class="item-arrow">›</text>
        </view>
      </view>

    </view>

    <!-- 退出登录按钮 -->
    <view class="logout-section">
      <view class="logout-btn" bindtap="logout" hover-class="logout-btn-hover">
        <text class="logout-btn-text">退出登录</text>
      </view>
    </view>

    <!-- 底部版本信息 -->
    <view class="footer-info">
      <view class="footer-logo-row">
        <text class="footer-brand">有个搭子</text>
      </view>
      <text class="footer-copyright">© 2024 有个搭子  版权所有</text>
      <text class="footer-version">Version 1.0.0 (Build 100)</text>
      <view class="footer-safe-area"></view>
    </view>

  </scroll-view>
</view>
