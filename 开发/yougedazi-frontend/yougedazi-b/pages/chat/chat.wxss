/* pages/chat/chat.wxss - 聊天页面样式 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F9FAFB;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 180rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 24rpx 32rpx;
}

/* 消息项 */
.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-item.system {
  justify-content: center;
}

.system-message {
  background: #E5E7EB;
  color: #6B7280;
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #F3F4F6;
  flex-shrink: 0;
}

/* 消息内容 */
.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-content.send {
  align-items: flex-end;
  margin-right: 20rpx;
}

.message-content.receive {
  align-items: flex-start;
  margin-left: 20rpx;
}

/* 消息气泡 */
.message-bubble {
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  position: relative;
  word-break: break-all;
}

.message-content.send .message-bubble {
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  border-bottom-right-radius: 4rpx;
}

.message-content.receive .message-bubble {
  background: #fff;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.message-text {
  font-size: 30rpx;
  line-height: 1.5;
}

.message-content.send .message-text {
  color: #fff;
}

.message-content.receive .message-text {
  color: #1F2937;
}

/* 时间和状态 */
.message-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.status-icon {
  font-size: 24rpx;
  color: #9CA3AF;
}

.status-icon.sent {
  color: #7B68EE;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #F3F4F6;
}

.input-wrapper {
  flex: 1;
  background: #F9FAFB;
  border-radius: 40rpx;
  padding: 0 32rpx;
}

.message-input {
  height: 80rpx;
  font-size: 30rpx;
  color: #1F2937;
}

.message-input::placeholder {
  color: #9CA3AF;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: #E5E7EB;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn text {
  font-size: 28rpx;
  color: #9CA3AF;
  font-weight: 600;
}

.send-btn.active {
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.3);
}

.send-btn.active text {
  color: #fff;
}
