/* pages/face-verify/face-verify.wxss - 人脸识别样式 */

.page-face-verify {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  box-sizing: border-box;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 头部说明 */
.verify-header {
  text-align: center;
  padding: 40rpx;
  margin-bottom: 60rpx;
}

.header-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.header-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 摄像头区域 */
.camera-section {
  position: relative;
  width: 480rpx;
  height: 480rpx;
  margin: 0 auto 60rpx;
}

.camera-box {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-box.scanning {
  border-color: #7B68EE;
  box-shadow: 0 0 40rpx rgba(123, 104, 238, 0.5);
}

.camera-box.success {
  border-color: #10B981;
  box-shadow: 0 0 40rpx rgba(16, 185, 129, 0.5);
}

.camera-box.fail {
  border-color: #EF4444;
  box-shadow: 0 0 40rpx rgba(239, 68, 68, 0.5);
}

.camera-box.locked {
  border-color: #9CA3AF;
  box-shadow: 0 0 40rpx rgba(156, 163, 175, 0.3);
}

/* 人脸框 */
.face-frame {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.frame-corner {
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-color: #7B68EE;
  border-style: solid;
}

.frame-corner.top-left {
  top: -4rpx;
  left: -4rpx;
  border-width: 6rpx 0 0 6rpx;
  border-top-left-radius: 20rpx;
}

.frame-corner.top-right {
  top: -4rpx;
  right: -4rpx;
  border-width: 6rpx 6rpx 0 0;
  border-top-right-radius: 20rpx;
}

.frame-corner.bottom-left {
  bottom: -4rpx;
  left: -4rpx;
  border-width: 0 0 6rpx 6rpx;
  border-bottom-left-radius: 20rpx;
}

.frame-corner.bottom-right {
  bottom: -4rpx;
  right: -4rpx;
  border-width: 0 6rpx 6rpx 0;
  border-bottom-right-radius: 20rpx;
}

/* 扫描线 */
.scan-line {
  position: absolute;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #7B68EE, transparent);
  animation: scan 2s linear infinite;
}

@keyframes scan {
  0% { transform: translateY(-200rpx); }
  100% { transform: translateY(200rpx); }
}

/* 状态提示 */
.status-tip {
  position: absolute;
  bottom: 60rpx;
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

/* 模拟摄像头 */
.camera-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

.camera-placeholder.locked {
  background: rgba(156, 163, 175, 0.2);
}

/* 操作按钮 */
.action-section {
  margin-bottom: 40rpx;
}

.btn-verify {
  width: 80%;
  height: 96rpx;
  margin: 0 auto 30rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.3);
}

.btn-verify.disabled {
  opacity: 0.6;
}

.btn-verify.btn-service {
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
}

.btn-cancel {
  text-align: center;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 倒计时提示 */
.timeout-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  padding: 20rpx 40rpx;
  background: rgba(239, 68, 68, 0.2);
  border-radius: 40rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #EF4444;
}

/* 说明文字 */
.verify-tips {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  padding: 30rpx;
}

.tip-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.tip-item {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.8;
}

/* 开发者跳过 */
.dev-skip {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  text-decoration: underline;
}

/* 失败统计提示 */
.attempts-tip {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 16rpx 30rpx;
  background: rgba(239, 68, 68, 0.15);
  border-radius: 32rpx;
}

.tip-warning {
  font-size: 26rpx;
  color: #EF4444;
  font-weight: 500;
}

/* 每日统计 */
.daily-stats {
  text-align: center;
  margin-bottom: 30rpx;
}

.stats-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}
