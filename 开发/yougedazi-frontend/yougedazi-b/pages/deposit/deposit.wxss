/* pages/deposit/deposit.wxss - 保证金页面样式 */

.page-deposit {
  min-height: 100vh;
  background: #F9FAFB;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: linear-gradient(135deg, #F59E0B, #D97706);
  padding-top: 60rpx;
}

.header-left {
  width: 60rpx;
}

.icon-back {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 60rpx;
}

/* 保证金概览 */
.deposit-overview {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  padding: 40rpx 32rpx 80rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.overview-card {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  backdrop-filter: blur(10rpx);
}

.overview-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  display: block;
  margin-bottom: 16rpx;
}

.overview-amount {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.overview-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

/* 保证金档位 */
.deposit-levels {
  margin: -40rpx 32rpx 24rpx;
}

.level-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  border: 4rpx solid transparent;
  transition: all 0.3s;
}

.level-card.active {
  border-color: #F59E0B;
  background: #FFFBEB;
}

.level-card.completed {
  border-color: #10B981;
  background: #F0FDF4;
}

.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.level-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.level-badge {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.level-badge.current {
  background: #FEF3C7;
  color: #D97706;
}

.level-badge.completed {
  background: #D1FAE5;
  color: #059669;
}

.level-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 24rpx;
}

.level-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #E5E7EB;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #F59E0B, #D97706);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #F59E0B;
  font-weight: 600;
  min-width: 80rpx;
  text-align: right;
}

/* 充值区域 */
.recharge-section {
  background: #fff;
  margin: 24rpx 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 24rpx;
}

.amount-options {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.amount-option {
  width: calc(33.333% - 14rpx);
  padding: 30rpx 0;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.2s;
}

.amount-option.selected {
  background: #FFFBEB;
  border-color: #F59E0B;
}

.amount-option .amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  display: block;
}

.amount-option .label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
  display: block;
}

.amount-option.selected .amount,
.amount-option.selected .label {
  color: #D97706;
}

/* 充值按钮 */
.recharge-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.3);
}

.recharge-btn::after {
  border: none;
}

.recharge-btn:active {
  transform: scale(0.98);
}

/* 保证金说明 */
.deposit-info {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-dot {
  width: 8rpx;
  height: 8rpx;
  background: #F59E0B;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}
