/* pages/message/message.wxss - 消息中心样式 */

.container {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 消息类型切换 */
.message-tabs {
  display: flex;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  padding: 40rpx 32rpx 40rpx;
  gap: 40rpx;
}

.tab-item {
  position: relative;
  padding: 16rpx 0;
  font-size: 32rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tab-item.active {
  color: #fff;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

.tab-item .badge {
  min-width: 36rpx;
  height: 36rpx;
  background: #EF4444;
  color: #fff;
  font-size: 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

/* 消息列表 */
.message-list {
  padding: 24rpx 0;
  padding-left: 32rpx;
}

/* 滑动区域 - 宽度包含消息和删除按钮 */
.movable-area {
  width: calc(100% + 160rpx);
  height: 160rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.movable-view {
  width: calc(100% - 160rpx);
  height: 160rpx;
  position: relative;
  z-index: 2;
}

/* 删除按钮 - 在消息卡片右侧，默认被遮挡 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  width: 160rpx;
  height: 160rpx;
  background: #EF4444;
  border-radius: 0 24rpx 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}

.delete-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx 0 0 24rpx;
  padding: 32rpx;
  height: 160rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  margin-right: 0;
}

.message-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.message-icon.icon-order {
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
}

.message-icon.icon-money {
  background: linear-gradient(135deg, #10B981, #059669);
}

.message-icon.icon-system {
  background: linear-gradient(135deg, #3B82F6, #2563EB);
}

.message-icon .icon-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-header .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.message-header .time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.message-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.message-body .desc {
  font-size: 28rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #EF4444;
  border-radius: 50%;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* 聊天项 */
.chat-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx 0 0 24rpx;
  padding: 32rpx;
  height: 160rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.chat-item .avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid #F3F4F6;
  flex-shrink: 0;
}

.chat-content {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chat-header .name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.chat-header .time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.chat-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chat-body .last-message {
  font-size: 28rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.unread-badge {
  min-width: 40rpx;
  height: 40rpx;
  background: #EF4444;
  color: #fff;
  font-size: 24rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  margin-left: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.4;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #6B7280;
}
