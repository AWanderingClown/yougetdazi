<!-- pages/task-square/task-square.wxml -->
<view class="page-task-square">
  <!-- 自定义导航头部 -->
  <view class="custom-nav">
    <view class="nav-left">
      <text class="nav-back-icon" bindtap="goBack">‹</text>
    </view>
    <view class="nav-center">
      <text class="nav-title">任务广场</text>
    </view>
    <view class="nav-right"></view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view 
      class="filter-item {{filterType === 'all' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-type="all"
    >
      全部
    </view>
    <view 
      class="filter-item {{filterType === 'nearby' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-type="nearby"
    >
      附近
    </view>
    <view 
      class="filter-item {{filterType === 'highpay' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-type="highpay"
    >
      高价
    </view>
    <view 
      class="filter-item {{filterType === 'match' ? 'active' : ''}}" 
      bindtap="onFilterChange" 
      data-type="match"
    >
      我能接
    </view>
  </view>

  <!-- 任务列表 -->
  <scroll-view 
    class="task-list" 
    scroll-y 
    refresher-enabled="{{true}}" 
    refresher-triggered="{{isRefreshing}}" 
    bindrefresherrefresh="onRefresh" 
    bindscrolltolower="onLoadMore"
  >
    <!-- 任务卡片列表 -->
    <block wx:if="{{tasks.length > 0}}">
      <view class="task-card" wx:for="{{tasks}}" wx:key="id" bindtap="onTaskTap" data-id="{{item.id}}">
        <!-- 卡片头部 -->
        <view class="task-card-header">
          <view class="service-type">
            <text class="type-icon">{{item.icon || '📋'}}</text>
            <text class="type-name">{{item.service_name || item.serviceType}}</text>
          </view>
          <view class="tag-group">
            <text class="tag tag-new" wx:if="{{item.isNew}}">新发布</text>
            <text class="tag tag-urgent" wx:if="{{item.isUrgent}}">急单</text>
          </view>
        </view>

        <!-- 价格区域 -->
        <view class="task-card-price">
          <view class="price-main">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.totalAmount || item.price || 0}}</text>
            <text class="price-unit">/小时</text>
          </view>
          <text class="price-total">预计 ¥{{item.totalAmount || item.price * (item.duration || 2)}}</text>
        </view>

        <!-- 任务详情信息 -->
        <view class="task-card-info">
          <view class="info-row">
            <view class="info-item">
              <text class="info-icon">⏱️</text>
              <text class="info-text">{{item.duration || 2}}小时</text>
            </view>
            <view class="info-item">
              <text class="info-icon">📍</text>
              <text class="info-text">{{item.distance || '未知'}}</text>
            </view>
          </view>
          <view class="info-row">
            <view class="info-item">
              <text class="info-icon">🕐</text>
              <text class="info-text">{{item.appointment_time || item.appointmentTime || '待确认'}}</text>
            </view>
          </view>
        </view>

        <!-- 卡片底部用户信息 -->
        <view class="task-card-footer">
          <view class="user-info">
            <image 
              class="user-avatar" 
              src="{{item.user && item.user.avatar || '/assets/icons/default-avatar.png'}}" 
              mode="aspectFill"
            />
            <view class="user-detail">
              <text class="user-name">{{item.user && item.user.nickname || '用户'}}</text>
              <text class="user-tags" wx:if="{{item.userType}}">
                <text class="tag-user" wx:if="{{item.userType === 'new'}}">新用户</text>
                <text class="tag-user regular" wx:if="{{item.userType === 'regular'}}">老客户</text>
              </text>
            </view>
          </view>
          <view 
            class="grab-btn {{item.canGrab ? 'active' : 'disabled'}}" 
            catchtap="onGrabTap" 
            data-id="{{item.id}}" 
            data-can-grab="{{item.canGrab}}"
          >
            {{item.canGrab ? '立即抢单' : '已抢满'}}
          </view>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <block wx:else>
      <view class="empty-state">
        <view class="empty-icon-wrapper">
          <text class="empty-emoji">📭</text>
        </view>
        <text class="empty-title">暂无任务</text>
        <text class="empty-desc">稍后再来看看吧~</text>
      </view>
    </block>

    <!-- 加载更多 -->
    <view class="loading-more" wx:if="{{isLoadingMore}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && tasks.length > 0}}">
      <text class="no-more-text">没有更多了</text>
    </view>
  </scroll-view>
</view>

<!-- 抢单确认弹窗 -->
<view class="grab-modal" wx:if="{{showGrabModal}}">
  <view class="modal-mask" bindtap="onCloseModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">确认抢单</text>
      <text class="modal-close" bindtap="onCloseModal">×</text>
    </view>
    <view class="modal-body">
      <view class="task-info-row">
        <text class="info-label">服务类型</text>
        <text class="info-value">{{selectedTask.service_name || selectedTask.serviceType}}</text>
      </view>
      <view class="task-info-row">
        <text class="info-label">服务时长</text>
        <text class="info-value">{{selectedTask.duration || 2}}小时</text>
      </view>
      <view class="task-info-row">
        <text class="info-label">服务地点</text>
        <text class="info-value">{{selectedTask.address || '用户指定地点'}}</text>
      </view>
      <view class="task-info-row">
        <text class="info-label">预计收益</text>
        <text class="info-value price">¥{{selectedTask.totalAmount || 0}}</text>
      </view>
      
      <view class="notice-section">
        <text class="notice-title">抢单须知</text>
        <view class="notice-item">• 抢单后需进行人脸识别验证</view>
        <view class="notice-item">• 请在预约时间前到达指定地点</view>
        <view class="notice-item">• 取消订单将扣除保证金50元</view>
        <view class="notice-item">• 爽约将影响您的接单优先级</view>
      </view>
      
      <view class="confirm-checkbox" bindtap="toggleConfirm">
        <view class="checkbox {{isConfirmed ? 'checked' : ''}}">
          <text wx:if="{{isConfirmed}}">✓</text>
        </view>
        <text class="confirm-text">我已阅读并同意以上条款</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="onCloseModal">取消</view>
      <view class="modal-btn confirm {{isConfirmed ? '' : 'disabled'}}" bindtap="onConfirmGrab">立即抢单</view>
    </view>
  </view>
</view>