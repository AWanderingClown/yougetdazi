/* pages/audit-result/audit-result.wxss - 审核结果样式 */

.container {
  min-height: 100vh;
  background: #F9FAFB;
}

/* ========== 自定义导航栏 ========== */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 220rpx;
  padding: 0 24rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, #7B68EE 0%, #9B59B6 100%);
  position: relative;
  z-index: 10;
}

.nav-left, .nav-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 56rpx;
  color: #ffffff;
  font-weight: bold;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
}

.result-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  margin: 40rpx;
}

.status-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 40rpx;
}

.status-icon.pending {
  background: #FEF3C7;
}

.status-icon.success {
  background: #D1FAE5;
}

.status-icon.reject {
  background: #FEE2E2;
}

.status-icon .icon {
  font-size: 80rpx;
}

.status-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  display: block;
  margin-bottom: 20rpx;
}

.status-desc {
  font-size: 28rpx;
  color: #9CA3AF;
  display: block;
  margin-bottom: 40rpx;
}

/* 进度列表 */
.progress-list {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 40rpx;
}

.progress-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.progress-item .dot {
  width: 20rpx;
  height: 20rpx;
  background: #E5E7EB;
  border-radius: 50%;
  margin-bottom: 12rpx;
}

.progress-item .text {
  font-size: 24rpx;
  color: #9CA3AF;
}

.progress-item.done .dot {
  background: #10B981;
}

.progress-item.done .text {
  color: #10B981;
}

.progress-item.doing .dot {
  background: #F59E0B;
  animation: pulse 1.5s infinite;
}

.progress-item.doing .text {
  color: #F59E0B;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.tip-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 权益列表 */
.benefits {
  margin-bottom: 40rpx;
}

.benefit-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F3F4F6;
}

.benefit-item:last-child {
  border-bottom: none;
}

.benefit-item .icon {
  font-size: 40rpx;
}

.benefit-item .text {
  font-size: 28rpx;
  color: #4B5563;
}

/* 拒绝原因 */
.reject-reason {
  background: #FEE2E2;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.reason-title {
  font-size: 28rpx;
  color: #DC2626;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.reason-content {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.6;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-text {
  background: transparent;
  color: #7B68EE;
  font-size: 28rpx;
}

.btn-text::after {
  border: none;
}

/* 底部 */
.footer {
  text-align: center;
  margin-top: 60rpx;
  font-size: 26rpx;
  color: #9CA3AF;
}

.footer .link {
  color: #7B68EE;
  margin-left: 8rpx;
}
