/* pages/earnings/earnings.wxss - 收益明细样式 */
.page-earnings {
  min-height: 100vh;
  background: #F9FAFB;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  padding-top: 60rpx;
}

.header-left {
  width: 60rpx;
}

.icon-back {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.header-right {
  width: 60rpx;
}

/* 收益概览 */
.earnings-overview {
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  padding: 30rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.total-card {
  background: rgba(255,255,255,0.2);
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  position: relative;
}

.total-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

.total-amount {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  margin: 10rpx 0;
}

.withdraw-btn {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  background: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #7B68EE;
  display: flex;
  align-items: center;
  gap: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.arrow {
  font-size: 24rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.3);
}

/* 余额行 */
.balance-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  margin-top: 20rpx;
}

.balance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.balance-value {
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 8rpx;
}

.balance-value.withdrawable {
  color: #fff;
}

.balance-value.pending {
  color: rgba(255,255,255,0.7);
}

.balance-divider {
  width: 2rpx;
  background: rgba(255,255,255,0.3);
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 20rpx 30rpx;
  margin-top: 20rpx;
}

.date-filter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.date-picker {
  background: #F9FAFB;
  padding: 16rpx 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1F2937;
  min-width: 180rpx;
  text-align: center;
  border: 2rpx solid #E5E7EB;
}

.date-separator {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 标签页 */
.tabs {
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #F3F4F6;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #4B5563;
  position: relative;
}

.tab.active {
  color: #7B68EE;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  border-radius: 2rpx;
}

/* 收益列表 */
.earnings-list {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F3F4F6;
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
}

.total-count {
  font-size: 24rpx;
  color: #9CA3AF;
  font-weight: normal;
}

.list-content {
  padding: 0 30rpx;
}

.income-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.income-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #7B68EE, #9B59B6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.item-title {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
}

.item-time {
  font-size: 24rpx;
  color: #9CA3AF;
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.item-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #10B981;
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.item-status.settled {
  color: #10B981;
  background: #D1FAE5;
}

.item-status.pending {
  color: #F59E0B;
  background: #FEF3C7;
}

/* 加载更多 */
.load-more, .no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #4B5563;
  margin-top: 30rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}
