<!-- pages/earnings/earnings.wxml - 收益明细 -->
<view class="page-earnings">
  <!-- 头部 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="icon-back">‹</text>
    </view>
    <text class="header-title">收益明细</text>
    <view class="header-right"></view>
  </view>

  <!-- 收益概览 -->
  <view class="earnings-overview">
    <view class="total-card">
      <text class="total-label">累计收益（元）</text>
      <text class="total-amount">{{totalIncome}}</text>
      <view class="withdraw-btn" bindtap="goToWithdraw">
        <text>去提现</text>
        <text class="arrow">›</text>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">¥{{todayIncome}}</text>
        <text class="stat-label">今日收益</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">¥{{weekIncome}}</text>
        <text class="stat-label">本周收益</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">¥{{monthIncome}}</text>
        <text class="stat-label">本月收益</text>
      </view>
    </view>

    <view class="balance-row">
      <view class="balance-item">
        <text class="balance-label">可提现</text>
        <text class="balance-value withdrawable">¥{{withdrawableAmount}}</text>
      </view>
      <view class="balance-divider"></view>
      <view class="balance-item">
        <text class="balance-label">待结算</text>
        <text class="balance-value pending">¥{{pendingAmount}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="date-filter">
      <picker mode="date" value="{{startDate}}" end="{{endDate}}" bindchange="onStartDateChange">
        <view class="date-picker">
          <text>{{startDate || '开始日期'}}</text>
        </view>
      </picker>
      <text class="date-separator">至</text>
      <picker mode="date" value="{{endDate}}" start="{{startDate}}" bindchange="onEndDateChange">
        <view class="date-picker">
          <text>{{endDate || '结束日期'}}</text>
        </view>
      </picker>
    </view>
  </view>

  <!-- 标签页 -->
  <view class="tabs">
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" 
          data-index="0" 
          bindtap="onTabChange">
      <text>{{tabs[0]}}</text>
    </view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" 
          data-index="1" 
          bindtap="onTabChange">
      <text>{{tabs[1]}}</text>
    </view>
    <view class="tab {{currentTab === 2 ? 'active' : ''}}" 
          data-index="2" 
          bindtap="onTabChange">
      <text>{{tabs[2]}}</text>
    </view>
  </view>

  <!-- 收益列表 -->
  <view class="earnings-list">
    <view class="list-header">
      <text>收入明细</text>
      <text class="total-count">共{{incomeList.length}}笔</text>
    </view>

    <view class="list-content">
      <block wx:if="{{incomeList.length > 0}}">
        <view class="income-item" 
              wx:for="{{incomeList}}" 
              wx:key="id"
              bindtap="viewDetail"
              data-item="{{item}}">
          <view class="item-left">
            <view class="item-icon">{{item.icon}}</view>
            <view class="item-info">
              <text class="item-title">{{item.title}}</text>
              <text class="item-time">{{item.time}}</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-amount">+¥{{item.amount}}</text>
            <text class="item-status {{item.status}}">{{item.status === 'settled' ? '已结算' : '待结算'}}</text>
          </view>
        </view>

        <!-- 加载更多 -->
        <view class="load-more" wx:if="{{hasMore}}">
          <text wx:if="{{isLoading}}">加载中...</text>
          <text wx:else>上拉加载更多</text>
        </view>
        <view class="no-more" wx:else>
          <text>没有更多了</text>
        </view>
      </block>

      <view class="empty-state" wx:else>
        <image class="empty-icon" src="/assets/icons/empty-order.png" mode="aspectFit"/>
        <text class="empty-text">暂无收益记录</text>
        <text class="empty-subtext">快去接单赚钱吧~</text>
      </view>
    </view>
  </view>
</view>
