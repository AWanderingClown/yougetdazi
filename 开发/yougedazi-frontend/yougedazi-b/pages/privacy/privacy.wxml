<!-- pages/privacy/privacy.wxml - 隐私政策 -->
<view class="page-privacy">
  <!-- 头部 -->
  <view class="header">
    <view class="header-left" bindtap="goBack">
      <text class="icon-back">‹</text>
    </view>
    <text class="header-title">隐私政策</text>
    <view class="header-right"></view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-wrapper" scroll-y>
    <view class="content">
      <view class="title">{{title}}</view>
      <text class="privacy-text">{{content}}</text>
    </view>
  </scroll-view>
</view>
