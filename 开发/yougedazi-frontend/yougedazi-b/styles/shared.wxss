/* styles/shared.wxss - 有个搭子 B端共享样式 */

/* ==================== 颜色变量 ==================== */
page {
  /* 主色调 */
  --color-primary: #7B68EE;
  --color-primary-light: #9B59B6;
  --color-primary-dark: #6A5ACD;
  --color-primary-bg: #F0E6FF;
  
  /* 功能色 */
  --color-success: #10B981;
  --color-success-bg: #D1FAE5;
  --color-warning: #F59E0B;
  --color-warning-bg: #FEF3C7;
  --color-error: #EF4444;
  --color-error-bg: #FEE2E2;
  --color-info: #3B82F6;
  --color-info-bg: #DBEAFE;
  
  /* 中性色 */
  --color-title: #1F2937;
  --color-text: #4B5563;
  --color-text-secondary: #9CA3AF;
  --color-placeholder: #D1D5DB;
  --color-border: #E5E7EB;
  --color-divider: #F3F4F6;
  --color-bg: #F9FAFB;
  --color-white: #FFFFFF;
  
  /* 状态色 */
  --status-working: #10B981;
  --status-resting: #9CA3AF;
  --status-pending: #F59E0B;
  --status-accepted: #3B82F6;
  --status-serving: #7B68EE;
  --status-completed: #10B981;
}

/* ==================== 基础重置 ==================== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background: var(--color-bg);
  color: var(--color-text);
  line-height: 1.6;
}

/* ==================== 排版工具类 ==================== */
.text-display { font-size: 48rpx; font-weight: bold; line-height: 1.2; }
.text-h1 { font-size: 40rpx; font-weight: bold; line-height: 1.3; }
.text-h2 { font-size: 36rpx; font-weight: 600; line-height: 1.3; }
.text-h3 { font-size: 32rpx; font-weight: 500; line-height: 1.4; }
.text-body { font-size: 30rpx; font-weight: normal; line-height: 1.6; }
.text-small { font-size: 26rpx; font-weight: normal; line-height: 1.5; }
.text-caption { font-size: 24rpx; font-weight: normal; line-height: 1.5; }
.text-mini { font-size: 22rpx; font-weight: normal; line-height: 1.4; }

/* 文字颜色 */
.text-primary { color: var(--color-primary); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-error { color: var(--color-error); }
.text-title { color: var(--color-title); }
.text-secondary { color: var(--color-text-secondary); }
.text-white { color: var(--color-white); }

/* ==================== 间距工具类 ==================== */
.m-1 { margin: 8rpx; }
.m-2 { margin: 16rpx; }
.m-3 { margin: 24rpx; }
.m-4 { margin: 32rpx; }

.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }

.mb-1 { margin-bottom: 8rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mb-4 { margin-bottom: 32rpx; }

.ml-1 { margin-left: 8rpx; }
.ml-2 { margin-left: 16rpx; }
.mr-1 { margin-right: 8rpx; }
.mr-2 { margin-right: 16rpx; }

.p-1 { padding: 8rpx; }
.p-2 { padding: 16rpx; }
.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }

.px-3 { padding-left: 24rpx; padding-right: 24rpx; }
.px-4 { padding-left: 32rpx; padding-right: 32rpx; }
.py-2 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-3 { padding-top: 24rpx; padding-bottom: 24rpx; }

/* ==================== 布局工具类 ==================== */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-1 { gap: 8rpx; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }

/* ==================== 卡片样式 ==================== */
.card {
  background: var(--color-white);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-flat {
  background: var(--color-white);
  border-radius: 24rpx;
}

.card-elevated {
  background: var(--color-white);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
}

/* ==================== 按钮样式 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
  color: var(--color-white);
  box-shadow: 0 8rpx 24rpx rgba(123, 104, 238, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(123, 104, 238, 0.2);
}

.btn-secondary {
  background: var(--color-white);
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.btn-secondary:active {
  background: var(--color-primary-bg);
}

.btn-small {
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.btn-text {
  height: auto;
  background: transparent;
  color: var(--color-primary);
  font-size: 28rpx;
}

/* ==================== 输入框样式 ==================== */
.input {
  height: 96rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: var(--color-title);
  transition: all 0.2s ease;
}

.input::placeholder {
  color: var(--color-placeholder);
}

.input:focus {
  background: var(--color-white);
  box-shadow: 0 0 0 2rpx var(--color-primary);
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
}

.tag-success {
  background: var(--color-success-bg);
  color: var(--color-success);
}

.tag-warning {
  background: var(--color-warning-bg);
  color: var(--color-warning);
}

.tag-error {
  background: var(--color-error-bg);
  color: var(--color-error);
}

/* ==================== 通用头部 ==================== */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-top: 60rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
}

.page-header-left,
.page-header-right {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.page-header-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-white);
}

.icon-back {
  font-size: 48rpx;
  color: var(--color-white);
  font-weight: bold;
}

/* ==================== 分隔线 ==================== */
.divider {
  height: 2rpx;
  background: var(--color-divider);
  margin: 24rpx 0;
}

.divider-vertical {
  width: 2rpx;
  background: var(--color-divider);
  align-self: stretch;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  margin-top: 24rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: var(--color-placeholder);
  margin-top: 12rpx;
}

/* ==================== 加载状态 ==================== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* ==================== 安全区域 ==================== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
